# Copy to .env and fill in. .env is gitignored — never commit a real key.

# Required: your Nimble API key. Get one at https://app.nimbleway.com
NIMBLE_API_KEY=

# Optional: a model the example apps route through (plain-string IDs route via
# the Vercel AI Gateway when AI_GATEWAY_API_KEY is set).
# AI_GATEWAY_API_KEY=
